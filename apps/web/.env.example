# ── License signing ────────────────────────────────────────────────────────
# JWK of the ES256 private key used to sign Pluck Pro licenses.
# Generated by `pnpm gen-license-keys`. Never commit the populated value.
LICENSE_PRIVATE_KEY=

# ── NOWPayments (crypto checkout) ──────────────────────────────────────────
# API key from NOWPayments dashboard → API keys.
# Used by /api/nowpayments/create-invoice to create hosted-checkout invoices.
NOWPAYMENTS_API_KEY=

# IPN secret from NOWPayments dashboard → Store settings → IPN.
# Used by /api/nowpayments/ipn to verify HMAC-SHA512 callback signatures.
# Endpoint refuses every request with 503 until this is set (safeguard).
NOWPAYMENTS_IPN_SECRET=

# ── Email delivery (Resend) ────────────────────────────────────────────────
# Optional. Without it, license-delivery emails are skipped — the webhook
# still mints + logs the license, so support can manually forward.
RESEND_API_KEY=
# Optional override for the From: address. Default: Pluck <onboarding@resend.dev>
# (Resend's catch-all sender — works without a verified domain).
RESEND_FROM=
# Optional override for the Reply-To address. Default points at the founder's
# inbox so customer replies to license emails come to the right person.
RESEND_REPLY_TO=
