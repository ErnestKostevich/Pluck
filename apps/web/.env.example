# ── License signing ────────────────────────────────────────────────────────
# JWK of the ES256 private key used to sign Pluck Pro licenses.
# Generated by `pnpm gen-license-keys`. Never commit the populated value.
LICENSE_PRIVATE_KEY=

# ── Polar.sh webhook ───────────────────────────────────────────────────────
# Webhook signing secret from your Polar dashboard. With this unset,
# /api/polar/webhook refuses every request with 503 (so the endpoint can't
# be abused to mint free licenses while it's not yet configured).
POLAR_WEBHOOK_SECRET=

# ── Email delivery (Resend) ────────────────────────────────────────────────
# Optional. Without it, license-delivery emails are skipped — the webhook
# still mints + logs the license, so support can manually forward.
RESEND_API_KEY=
# Optional override for the From: address (default: Pluck <licenses@pluck.app>)
RESEND_FROM=
